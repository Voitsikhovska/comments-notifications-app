<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "CommentHub" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-gray-50 min-h-screen">
    <nav class="bg-white border-b border-gray-200">
      <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
        <%= link_to "CommentHub", root_path, class: "text-lg font-bold text-gray-900" %>
        <div class="flex items-center gap-4">
          <% if user_signed_in? %>
            <%= link_to "Comments", comments_path, class: "link text-sm" %>
            <span class="text-sm text-gray-500">@<%= current_user.username %></span>
            <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn-danger" %>
          <% else %>
            <%= link_to "Sign in", new_user_session_path, class: "link" %>
            <%= link_to "Sign up", new_user_registration_path, class: "btn-primary" %>
          <% end %>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="max-w-4xl mx-auto px-4 mt-4">
        <p class="alert-success"><%= notice %></p>
      </div>
    <% end %>
    <% if alert %>
      <div class="max-w-4xl mx-auto px-4 mt-4">
        <p class="alert-notice"><%= alert %></p>
      </div>
    <% end %>

    <main class="max-w-4xl mx-auto px-4 py-8">
      <%= yield %>
    </main>
  </body>
</html>
