<%= form_with model: comment, url: url do |f| %>
  <% if comment.errors.any? %>
    <div class="alert-error mb-4">
      <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
        <% comment.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-field" data-controller="mention-autocomplete">
    <%= f.label :body, "Your comment", class: "form-label" %>
    <div class="relative">
      <%= f.text_area :body, rows: 4,
            placeholder: "Write a comment… use @username to mention someone",
            class: "form-input resize-none",
            data: { mention_autocomplete_target: "input",
                    action: "input->mention-autocomplete#onInput" } %>
      <div class="mention-dropdown hidden" data-mention-autocomplete-target="dropdown"></div>
    </div>
    <p class="text-hint mt-1"><%= comment.body.to_s.length %> / 1000</p>
  </div>

  <%= f.submit local_assigns.fetch(:submit_label, "Post comment"), class: "btn-primary w-full" %>
<% end %>

