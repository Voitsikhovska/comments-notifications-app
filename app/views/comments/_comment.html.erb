<div class="comment-card" id="<%= dom_id(comment) %>">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-2">
        <span class="font-semibold text-sm text-gray-900"><%= comment.user.username %></span>
        <% if comment.updated_at - comment.created_at > 5 %>
          <span class="text-hint">edited <%= time_ago_in_words(comment.updated_at) %> ago</span>
        <% else %>
          <span class="text-hint"><%= time_ago_in_words(comment.created_at) %> ago</span>
        <% end %>
      </div>
      <p class="comment-body"><%= comment.body %></p>
    </div>

    <% if comment.user == current_user %>
      <div class="flex items-center gap-2 shrink-0">
        <%= link_to "Edit", edit_comment_path(comment), class: "btn-edit" %>
        <button type="button" class="btn-delete"
                data-action="confirm-delete#show"
                data-confirm-url="<%= comment_path(comment) %>">
          Delete
        </button>
      </div>
    <% end %>
  </div>
</div>
