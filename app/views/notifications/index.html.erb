<% content_for :title, "Notifications" %>

<div class="max-w-2xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="page-title">
      Notifications
      <% if @unread_count > 0 %>
        <span class="text-sm font-normal text-blue-600 ml-1"><%= @unread_count %> unread</span>
      <% end %>
    </h1>
    <% if @notifications.any?(&:unread?) %>
      <%= button_to "Mark all as read", mark_all_read_notifications_path,
            method: :patch, class: "btn-secondary text-sm" %>
    <% end %>
  </div>

  <% if @notifications.empty? %>
    <div class="card p-8 text-center text-gray-400">
      No notifications yet. You'll be notified when someone mentions you.
    </div>
  <% else %>
    <div class="space-y-2">
      <%= render @notifications %>
    </div>
  <% end %>
</div>
