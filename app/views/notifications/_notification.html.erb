<div class="notification-item <%= notification.read? ? 'notification-read' : 'notification-unread' %>"
     id="<%= dom_id(notification) %>">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1">
      <p class="text-sm text-gray-800">
        <span class="font-semibold">@<%= notification.actor.username %></span>
        mentioned you in a comment
        <span class="text-hint"><%= time_ago_in_words(notification.created_at) %> ago</span>
      </p>
      <p class="notification-preview"><%= highlight_mentions(notification.comment.body) %></p>
    </div>

    <% unless notification.read? %>
      <%= button_to "Mark as read", notification_path(notification),
            method: :patch, class: "btn-mark-read shrink-0" %>
    <% end %>
  </div>
</div>
