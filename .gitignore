# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files (IMPORTANT: Don't commit secrets!)
/.env
/.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key
/config/master.key
/config/credentials/*.key

/app/assets/builds/*
!/app/assets/builds/.keep

# Node modules
/node_modules
/node_modules/
yarn-error.log
npm-debug.log*

# Coverage reports
/coverage/
/coverage

# Database files
*.sqlite3
*.sqlite3-journal
*.sqlite3-*
db/*.sqlite3
db/*.sqlite3-journal

# Docker-specific
docker-compose.override.yml
.dockerignore

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini

# Linux
*~
.directory
.Trash-*

# Editor and IDE files
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
.vs/

# RubyMine
.idea/
*.iml
*.ipr
*.iws

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Cursor IDE
.cursor/

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# Backup files
*.bak
*.backup
*.tmp
*.orig
*~

# Test coverage
coverage/
spec/reports/
test/reports/

# RSpec
spec/examples.txt

# Simplecov
coverage.data

# Byebug
.byebug_history

# Pry
.pry_history

# Redis dump
dump.rdb

# Elasticsearch data
elasticsearch/

# Yarn
yarn-error.log
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# Webpack
/public/packs
/public/packs-test
/public/webpack
/public/hot-update
/public/sw.js
/public/sw.js.map

# Tailwind CSS builds (already covered above but being explicit)
/app/assets/builds/

# Rails caching
/tmp/cache/

# Spring
/spring/*.pid

# Bootsnap
/tmp/cache/bootsnap*

# Asset compilation
/public/packs-test
/public/assets

# System test screenshots
/tmp/screenshots/

# Rails credentials
/config/credentials/development.key
/config/credentials/production.key

# Ignore uploaded files in public directory
/public/uploads/
/public/system/

# Ignore all dumps
*.dump
*.sql

# Ignore built documentation
doc/app/
doc/api/
.yardoc/

# Ignore ctags
tags
.tags
.tags_sorted_by_file
.gemtags

# Ignore pow config
.powrc
.powder

# RVM
.rvmrc

# rbenv (keep .ruby-version tracked - removed from ignore)
.ruby-gemset

# direnv
.envrc

# Local shell files
.local.sh
